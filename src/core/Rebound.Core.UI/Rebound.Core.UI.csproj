<Project Sdk="Microsoft.NET.Sdk">

	<!-- Generic -->
	<PropertyGroup>

		<!-- Code Analysis and Trimming -->
		<AnalysisMode>All</AnalysisMode>

		<!-- Language and Code Configuration -->
		<LangVersion>preview</LangVersion>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>

		<!-- Library Generic -->
		<UseWinUI>true</UseWinUI>
		<WinUISDKReferences>false</WinUISDKReferences>

		<!-- Targets -->
		<TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
		<TargetPlatformMinVersion>10.0.22000.0</TargetPlatformMinVersion>

		<!-- Platforms -->
		<Platforms>x64;ARM64</Platforms>

		<!-- Advanced -->
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<EnableDefaultPageItems>false</EnableDefaultPageItems>

		<DisableImplicitFrameworkReferences>false</DisableImplicitFrameworkReferences>
		<GenerateDependencyFile>true</GenerateDependencyFile>

	</PropertyGroup>

	<!-- Architecture -->
	<PropertyGroup>
		<PlatformTarget Condition="'$(Platform)' == 'x64'">x64</PlatformTarget>
		<PlatformTarget Condition="'$(Platform)' == 'ARM64' or $(RuntimeIdentifier.EndsWith('-arm64'))">arm64</PlatformTarget>
	</PropertyGroup>

	<!-- Project content -->
	<ItemGroup>
		<Page Include="UserControls\HomePageHeaderImage.xaml" />
	</ItemGroup>

	<!-- Package references -->
	<ItemGroup>
		<PackageReference Include="TerraFX.Interop.Windows" Version="10.0.26100.6" />
		<PackageReference Include="Microsoft.WindowsAppSDK.WinUI" Version="2.2.1" />
		<PackageReference Include="Microsoft.Graphics.Win2D" Version="1.4.0" />
		<PackageReference Include="WinUIEx" Version="2.9.1" />
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
		<PackageReference Include="CommunityToolkit.WinUI.Animations" Version="8.2.251219"> <ExcludeAssets>build;buildtransitive</ExcludeAssets> </PackageReference>
	</ItemGroup>

	<!-- Project references -->
	<ItemGroup>
		<ProjectReference Include="..\Rebound.Core.IPC\Rebound.Core.IPC.csproj" />
		<ProjectReference Include="..\Rebound.Core.Native\Rebound.Core.Native.csproj" />
		<ProjectReference Include="..\Rebound.Core.SystemInformation\Rebound.Core.SystemInformation.csproj" />
		<ProjectReference Include="..\Rebound.Core\Rebound.Core.csproj" />
	</ItemGroup>

</Project>