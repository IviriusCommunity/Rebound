<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
		<TargetPlatformMinVersion>10.0.22000.0</TargetPlatformMinVersion>
		<Platforms>x64;ARM64</Platforms>

		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<UseUwp>true</UseUwp>
		<IsPackable>false</IsPackable>
		<PackOnBuild>false</PackOnBuild>
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
	</PropertyGroup>
	<PropertyGroup>
		<PlatformTarget Condition="'$(Platform)' == 'x64'">x64</PlatformTarget>
		<PlatformTarget Condition="'$(Platform)' == 'ARM64' or $(RuntimeIdentifier.EndsWith('-arm64'))">arm64</PlatformTarget>
	</PropertyGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.UI.Xaml" Version="2.8.7" />
		<PackageReference Include="TerraFX.Interop.Windows" Version="10.0.26100.6" />
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
		<PackageReference Include="Microsoft.WindowsAppSDK.Base" Version="1.8.251216001" />
		<PackageReference Include="Microsoft.WindowsAppSDK.InteractiveExperiences" Version="1.8.260125001" />
		<PackageReference Include="CommunityToolkit.Uwp.Animations" Version="8.2.251219" />
		<PackageReference Include="Win2D.uwp" Version="1.28.3" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Rebound.Core.IPC\Rebound.Core.IPC.csproj" />
		<ProjectReference Include="..\Rebound.Core.Native\Rebound.Core.Native.csproj" />
		<ProjectReference Include="..\Rebound.Core.SystemInformation\Rebound.Core.SystemInformation.csproj" />
		<ProjectReference Include="..\Rebound.Core\Rebound.Core.csproj" />
	</ItemGroup>

</Project>
