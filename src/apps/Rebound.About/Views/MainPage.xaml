                                        <TextBlock
                                            Grid.Row="3"
                                            Text="Computer name"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Grid.Row="4"
                                            Text="Architecture"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Grid.Row="5"
                                            Text="Pagefile"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Grid.Row="6"
                                            Text="Device manufacturer"
