                            <muxc:ProgressBar
                                Grid.Row="2"
                                Margin="48,0,0,0"
                                Value="{x:Bind ViewModel.GpuUsage, Mode=OneWay}" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="16,0,48,0"
