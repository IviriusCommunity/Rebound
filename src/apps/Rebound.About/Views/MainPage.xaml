                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                            IsTextSelectionEnabled="True"
                                            Text="{x:Bind ViewModel.ComputerName, Mode=OneWay}"
