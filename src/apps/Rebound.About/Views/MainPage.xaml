                        <LinearGradientBrush.GradientStops>
                            <GradientStop Color="{ThemeResource SystemAccentColorLight2}" />
                            <GradientStop Offset="1" Color="{ThemeResource SystemAccentColor}" />
                        </LinearGradientBrush.GradientStops>
                    </LinearGradientBrush>
