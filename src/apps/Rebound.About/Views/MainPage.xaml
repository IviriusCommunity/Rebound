                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Grid.Row="7"
                                            Grid.Column="1"
                                            Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                            IsTextSelectionEnabled="True"
                                            Text="{x:Bind ViewModel.DeviceModel, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Grid.Row="8"
                                            Grid.Column="1"
                                            Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                            IsTextSelectionEnabled="True"
                                            Text="{x:Bind ViewModel.Uptime, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Grid.Row="9"
                                            Grid.Column="1"
                                            Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                            IsTextSelectionEnabled="True"
                                            Text="{x:Bind ViewModel.Locale, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Grid.Row="10"
                                            Grid.Column="1"
                                            Foreground="{ThemeResource TextFillColorDisabledBrush}"
