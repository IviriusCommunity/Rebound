<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Rebound.Cleanup.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedVisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:items="using:Rebound.Cleanup.Items"
    xmlns:local="using:Rebound.Cleanup.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:winuiex="using:WinUIEx"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:FileSizeToFriendlyStringConverter x:Key="FileSizeToFriendlyStringConverter" />
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <converters:BoolToObjectConverter
            x:Key="BoolToInverseVisibilityConverter"
            FalseValue="Visible"
            TrueValue="Collapsed" />
    </Page.Resources>
    <Grid>
        <SystemBackdropElement>
            <SystemBackdropElement.SystemBackdrop>
                <MicaBackdrop />
            </SystemBackdropElement.SystemBackdrop>
        </SystemBackdropElement>
        <StackPanel
            Margin="12,8,12,0"
            VerticalAlignment="Top"
            Orientation="Horizontal"
            Spacing="8">
            <Image Width="16" Source="/Assets/cleanmgr.ico" />
            <TextBlock FontSize="12" Text="Disk Cleanup" />
            <Border
                Padding="6,2,6,3"
                VerticalAlignment="Center"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="2">
                <TextBlock
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                    Text="BETA" />
            </Border>
        </StackPanel>
        <Grid Margin="0,32,0,0" RowSpacing="8">
            <NavigationView
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="False"
                SizeChanged="NavigationView_SizeChanged">
                <NavigationView.MenuItems>
                    <NavigationViewItem
                        x:Name="DiskCleanupItem"
                        Content="Disk Cleanup"
                        IsSelected="True">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xEA99;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem Content="Disk Analyzer">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xEB05;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem x:Name="MoreOptionsItem" Content="More Options">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE90F;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItemSeparator />
                    <NavigationViewItem Content="Disk Management">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem Content="Storage Sense">
                        <NavigationViewItem.Icon>
                            <PathIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="F1 M 4.52 6.2 C 4.679999 5.88 4.913333 5.619999 5.22 5.42 C 5.526667 5.219999 5.853333 5.119999 6.2 5.119999 L 13.799999 5.119999 C 14.146666 5.119999 14.473333 5.219999 14.78 5.42 C 15.086666 5.619999 15.319999 5.88 15.48 6.2 L 18.08 11.52 C 18.239998 11.893333 18.32 12.280001 18.32 12.679999 L 18.32 15.759999 C 18.32 16.266666 18.139999 16.706667 17.779999 17.08 C 17.419998 17.453333 16.973333 17.639999 16.440001 17.639999 L 3.56 17.639999 C 3.026667 17.639999 2.58 17.453333 2.22 17.08 C 1.86 16.706667 1.68 16.266666 1.68 15.759999 L 1.68 12.679999 C 1.68 12.280001 1.76 11.893333 1.92 11.52 Z M 14.36 6.719999 C 14.253333 6.506667 14.066666 6.400001 13.799999 6.4 L 6.2 6.4 C 5.933333 6.400001 5.746666 6.506667 5.64 6.719999 L 3.6 10.959999 L 16.4 10.959999 Z M 2.92 12.839999 L 2.92 15.759999 C 2.92 15.92 2.98 16.066666 3.1 16.199999 C 3.22 16.333332 3.373333 16.4 3.56 16.4 L 16.440001 16.4 C 16.626667 16.4 16.779999 16.333332 16.9 16.199999 C 17.02 16.066666 17.08 15.92 17.08 15.759999 L 17.08 12.839999 C 17.08 12.68 17.02 12.533333 16.9 12.4 C 16.779999 12.266666 16.626667 12.200001 16.440001 12.2 L 3.56 12.2 C 3.373333 12.200001 3.22 12.266666 3.1 12.4 C 2.98 12.533333 2.92 12.68 2.92 12.839999 Z M 15 15.119999 C 15.239999 15.12 15.439999 15.039999 15.599999 14.879999 C 15.759998 14.719999 15.839998 14.526667 15.839999 14.299999 C 15.839998 14.073334 15.759998 13.88 15.599999 13.719999 C 15.439999 13.559999 15.239999 13.48 15 13.48 C 14.759999 13.48 14.559999 13.559999 14.4 13.719999 C 14.24 13.88 14.16 14.073334 14.16 14.299999 C 14.16 14.526667 14.24 14.719999 14.4 14.879999 C 14.559999 15.039999 14.759999 15.12 15 15.119999 Z " />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem Content="Optimize Drives (Deprecated)">
                        <NavigationViewItem.Icon>
                            <ImageIcon Source="/Assets/dfrgui.ico" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.MenuItems>
                <Grid>
                    <Grid RowSpacing="8" Visibility="{x:Bind DiskCleanupItem.IsSelected, Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ComboBox
                            MaxWidth="800"
                            Margin="24,24,24,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Header="Selected drive"
                            ItemsSource="{x:Bind ViewModel.DriveItems, Mode=OneWay}"
                            SelectedIndex="{x:Bind ViewModel.SelectedDriveIndex, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="items:DriveComboBoxItem">
                                    <Grid>
                                        <ImageIcon
                                            Width="20"
                                            Margin="-2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Source="{x:Bind ImagePath, Mode=OneWay}" />
                                        <TextBlock
                                            Margin="24,0,0,0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Text="{x:Bind DriveName, Mode=OneWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <InfoBar
                            Title="Hover over an item for its description."
                            Grid.Row="1"
                            MaxWidth="800"
                            Margin="24,0"
                            IsClosable="False"
                            IsOpen="True" />
                        <Grid
                            Grid.Row="2"
                            MaxWidth="800"
                            Margin="24,0">
                            <CheckBox
                                Content="Select all"
                                IsChecked="{x:Bind ViewModel.IsEverythingSelected, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.CanItemsBeClicked, Mode=OneWay}" />
                            <Button
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Command="{x:Bind RefreshCommand}"
                                IsEnabled="{x:Bind ViewModel.CanItemsBeClicked, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                    <TextBlock Text="Refresh" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ListView
                            x:Name="ItemsListView"
                            Grid.Row="3"
                            MaxWidth="800"
                            Margin="24,0"
                            Padding="4,6"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            CornerRadius="4"
                            IsEnabled="{x:Bind ViewModel.CanItemsBeClicked, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.CleanItems, Mode=OneWay}"
                            SelectedIndex="0">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="items:CleanItem">
                                    <Grid ColumnSpacing="8" ToolTipService.ToolTip="{x:Bind Description, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox
                                            MinWidth="0"
                                            Checked="CheckBox_Checked"
                                            IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                            Unchecked="CheckBox_Checked" />
                                        <ImageIcon
                                            Grid.Column="1"
                                            Width="16"
                                            HorizontalAlignment="Left"
                                            Source="{x:Bind ImagePath, Mode=OneWay}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Text="{x:Bind Name, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                        <StackPanel
                                            Grid.Column="3"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            Visibility="{x:Bind IsEnumerated, Mode=OneWay, Converter={StaticResource BoolToInverseVisibilityConverter}}">
                                            <ProgressRing
                                                Width="16"
                                                Height="16"
                                                IsIndeterminate="True" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Opacity="0.5"
                                                Text="Indexing..." />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="4"
                                            VerticalAlignment="Center"
                                            Opacity="0.5"
                                            Text="{x:Bind Size, Mode=OneWay, Converter={StaticResource FileSizeToFriendlyStringConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid
                            Grid.Row="4"
                            MaxWidth="800"
                            Margin="24,0">
                            <TextBlock Opacity="0.5">
                                <Run Text="{x:Bind ViewModel.FilesCount, Mode=OneWay}" />
                                <Run Text=" files" />
                            </TextBlock>
                            <TextBlock
                                HorizontalAlignment="Right"
                                Opacity="0.5"
                                Text="{x:Bind ViewModel.FilesSize, Mode=OneWay, Converter={StaticResource FileSizeToFriendlyStringConverter}}" />
                        </Grid>
                        <StackPanel
                            Grid.Row="5"
                            MaxWidth="800"
                            Margin="24,0"
                            Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.CurrentOperation, Mode=OneWay}" />
                            <ProgressBar Maximum="{x:Bind ViewModel.MaxProgress, Mode=OneWay}" Value="{x:Bind ViewModel.CurrentProgress, Mode=OneWay}" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.CurrentTask, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Grid
                            Grid.Row="6"
                            MaxWidth="800"
                            Margin="24,4,24,8">
                            <StackPanel
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Command="{x:Bind ViewModel.RelaunchAsAdminCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanItemsBeClicked, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.IsRunningAsAdmin, Converter={StaticResource BoolToInverseVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ImageIcon Width="16" Source="ms-appx:///Assets/Administrator.png" />
                                        <TextBlock Text="Clean up system files" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Command="{x:Bind ViewModel.ViewFilesCommand}"
                                    CommandParameter="{x:Bind ItemsListView.SelectedIndex, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.CanItemsBeClicked, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE838;" />
                                        <TextBlock Text="View files" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Grid
                            Grid.Row="7"
                            Height="80"
                            Padding="24"
                            Background="{ThemeResource SystemControlBackgroundAltMediumLowBrush}">
                            <Grid MaxWidth="800">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    Grid.Column="1"
                                    Width="120"
                                    Command="{x:Bind ViewModel.DeleteCommand}"
                                    Content="Clean"
                                    IsEnabled="{x:Bind ViewModel.CanItemsBeClicked, Mode=OneWay}"
                                    Style="{ThemeResource AccentButtonStyle}" />
                                <Button
                                    Grid.Column="3"
                                    Width="120"
                                    Command="{x:Bind CloseCommand}"
                                    Content="Close"
                                    IsEnabled="{x:Bind ViewModel.CanItemsBeClicked, Mode=OneWay}">
                                    <Button.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="Escape" />
                                    </Button.KeyboardAccelerators>
                                </Button>
                            </Grid>
                        </Grid>
                    </Grid>
                    <Grid Visibility="{x:Bind MoreOptionsItem.IsSelected, Mode=OneWay}">
                        <StackPanel Margin="24" Spacing="8">
                            <Button
                                Padding="18,16,14,16"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Command="{x:Bind ViewModel.DeleteOldRestorePointsAndShadowCopiesCommand}">
                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.RowSpan="2" Glyph="&#xED62;" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="Delete shadow copies"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        FontSize="12"
                                        Opacity="0.75"
                                        Text="Remove all but the latest restore point and all shadow copies."
                                        TextWrapping="WrapWholeWords" />
                                    <FontIcon
                                        Grid.RowSpan="2"
                                        Grid.Column="2"
                                        FontSize="14"
                                        Glyph="" />
                                </Grid>
                            </Button>
                            <Button
                                Padding="18,16,14,16"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <interactivity:Interaction.Behaviors>
                                    <interactivity:EventTriggerBehavior EventName="Click">
                                        <behaviors:NavigateToUriAction NavigateUri="ms-settings:appsfeatures" />
                                    </interactivity:EventTriggerBehavior>
                                </interactivity:Interaction.Behaviors>
                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <FontIcon Grid.RowSpan="2" Glyph="&#xE74C;" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="Programs and features"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        FontSize="12"
                                        Opacity="0.75"
                                        Text="Remove programs you no longer need."
                                        TextWrapping="WrapWholeWords" />
                                    <FontIcon
                                        Grid.RowSpan="2"
                                        Grid.Column="2"
                                        FontSize="14"
                                        Glyph="&#xE8A7;" />
                                </Grid>
                            </Button>
                            <Button
                                Padding="18,16,14,16"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Command="{x:Bind ViewModel.LaunchDefragCommand}">
                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ImageIcon
                                        Grid.RowSpan="2"
                                        Width="20"
                                        Source="/Assets/dfrgui.ico" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="Optimize drives"
                                        TextWrapping="WrapWholeWords" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        FontSize="12"
                                        Opacity="0.75"
                                        Text="Defragment or trim your drives to speed them up."
                                        TextWrapping="WrapWholeWords" />
                                    <FontIcon
                                        Grid.RowSpan="2"
                                        Grid.Column="2"
                                        FontSize="14"
                                        Glyph="&#xE8A7;" />
                                </Grid>
                            </Button>
                        </StackPanel>
                        <Grid
                            Grid.Row="5"
                            Height="80"
                            Padding="24"
                            VerticalAlignment="Bottom"
                            Background="{ThemeResource SystemControlBackgroundAltMediumLowBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Button
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind CloseCommand}"
                                Content="OK"
                                IsEnabled="{x:Bind ViewModel.CanItemsBeClicked, Mode=OneWay}"
                                Style="{ThemeResource AccentButtonStyle}">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="Escape" />
                                </Button.KeyboardAccelerators>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </NavigationView>
        </Grid>
    </Grid>
</Page>