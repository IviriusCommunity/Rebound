<Page
    x:Class="Rebound.ControlPanel.Views.SystemConfigurationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:Rebound.ControlPanel.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolToVisibilityConverter
            x:Key="BoolToInverseVisibilityConverter"
            FalseValue="Visible"
            TrueValue="Collapsed" />
    </Page.Resources>
    <Grid>
        <Grid
            Height="72"
            VerticalAlignment="Top"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Image
                Width="20"
                Margin="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Source="/Assets/Apps/SystemConfiguration.ico" />
            <TextBlock
                Margin="48,10"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                Text="System Configuration" />
            <TextBlock Margin="48,40,0,0" Text="System configuration and properties." />
        </Grid>
        <ScrollViewer Margin="0,72,0,0" Padding="40,0,40,0">
            <StackPanel
                MaxWidth="1000"
                Margin="0,40"
                Spacing="8">
                <toolkit:SettingsCard
                    Description="Manage the settings that don't appear here."
                    Header="Windows Settings"
                    IsClickEnabled="True">
                    <interactivity:Interaction.Behaviors>
                        <interactivity:EventTriggerBehavior EventName="Tapped">
                            <behaviors:NavigateToUriAction NavigateUri="ms-settings:system" />
                        </interactivity:EventTriggerBehavior>
                    </interactivity:Interaction.Behaviors>
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE713;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <toolkit:SettingsCard.ActionIcon>
                        <FontIcon Glyph="&#xE8AD;" />
                    </toolkit:SettingsCard.ActionIcon>
                </toolkit:SettingsCard>
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="Computer information" />
                <muxc:InfoBar
                    Title="These settings require administrator privileges to edit."
                    IsClosable="False"
                    IsOpen="True"
                    Visibility="{x:Bind ViewModel.IsElevated, Mode=OneWay, Converter={StaticResource BoolToInverseVisibilityConverter}}">
                    <muxc:InfoBar.ActionButton>
                        <Button Command="{x:Bind ViewModel.RelaunchAsAdminCommand}" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xEA18;" />
                                <TextBlock Text="Relaunch as Administrator" />
                            </StackPanel>
                        </Button>
                    </muxc:InfoBar.ActionButton>
                </muxc:InfoBar>
                <toolkit:SettingsExpander Description="The display name of your computer. Only letters, numbers and hyphens allowed, max 15 characters. Cannot start or end with a hyphen. Requires a restart to apply." Header="Computer name">
                    <toolkit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE8AC;" />
                    </toolkit:SettingsExpander.HeaderIcon>
                    <toolkit:SettingsExpander.ItemsHeader>
                        <Grid Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <TextBox
                                IsEnabled="{x:Bind ViewModel.IsElevated, Mode=OneWay}"
                                MaxLength="15"
                                Text="{x:Bind ViewModel.ComputerName, Mode=TwoWay}" />
                        </Grid>
                    </toolkit:SettingsExpander.ItemsHeader>
                </toolkit:SettingsExpander>
                <toolkit:SettingsExpander Description="The description of your computer." Header="Computer description">
                    <toolkit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE946;" />
                    </toolkit:SettingsExpander.HeaderIcon>
                    <toolkit:SettingsExpander.ItemsHeader>
                        <Grid Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <TextBox
                                IsEnabled="{x:Bind ViewModel.IsElevated, Mode=OneWay}"
                                MaxLength="255"
                                Text="{x:Bind ViewModel.ComputerDescription, Mode=TwoWay}" />
                        </Grid>
                    </toolkit:SettingsExpander.ItemsHeader>
                </toolkit:SettingsExpander>
                <muxc:InfoBar
                    Title="Invalid computer name. Check the naming requirements above."
                    IsOpen="{x:Bind ViewModel.IsComputerNameError, Mode=TwoWay}"
                    Severity="Error" />
                <muxc:InfoBar
                    Title="You will need to restart in order for the computer name to be fully updated."
                    IsOpen="{x:Bind ViewModel.IsRestartRequired, Mode=TwoWay}"
                    Severity="Warning">
                    <muxc:InfoBar.ActionButton>
                        <Button Command="{x:Bind ViewModel.RestartCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE777;" />
                                <TextBlock Text="Restart now" />
                            </StackPanel>
                        </Button>
                    </muxc:InfoBar.ActionButton>
                </muxc:InfoBar>
                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Command="{x:Bind ViewModel.ApplyChangesCommand}"
                        IsEnabled="{x:Bind ViewModel.AreChangesPending, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="{x:Bind ViewModel.IsElevated, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xE73E;" />
                            <TextBlock Text="Apply" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.CancelChangesCommand}"
                        IsEnabled="{x:Bind ViewModel.AreChangesPending, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsElevated, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xE711;" />
                            <TextBlock Text="Cancel" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="Hardware" />
                <toolkit:SettingsCard
                    Command="{x:Bind LaunchDeviceManagerCommand}"
                    Description="Manage device drivers."
                    Header="Device Manager"
                    IsClickEnabled="True">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEB66;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <toolkit:SettingsCard.ActionIcon>
                        <FontIcon Glyph="&#xE8AD;" />
                    </toolkit:SettingsCard.ActionIcon>
                </toolkit:SettingsCard>
                <muxc:InfoBar
                    Title="This setting requires administrator privileges to view and edit."
                    IsClosable="False"
                    IsOpen="True"
                    Visibility="{x:Bind ViewModel.IsElevated, Mode=OneWay, Converter={StaticResource BoolToInverseVisibilityConverter}}">
                    <muxc:InfoBar.ActionButton>
                        <Button Command="{x:Bind ViewModel.RelaunchAsAdminCommand}" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xEA18;" />
                                <TextBlock Text="Relaunch as Administrator" />
                            </StackPanel>
                        </Button>
                    </muxc:InfoBar.ActionButton>
                </muxc:InfoBar>
                <toolkit:SettingsCard
                    Description="Controls whether Windows automatically downloads device metadata and OEM apps from the Windows Metadata and Internet Services (WMIS) server for connected devices. When enabled, Windows will silently install manufacturer apps (e.g. Lenovo Vantage) upon connecting hardware. Disable to prevent unsolicited OEM software installation."
                    Header="OEM apps"
                    IsEnabled="{x:Bind ViewModel.IsElevated, Mode=OneWay}">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE74C;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.InstallOemApps, Mode=TwoWay}" Visibility="{x:Bind ViewModel.IsElevated, Mode=OneWay}" />
                </toolkit:SettingsCard>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
