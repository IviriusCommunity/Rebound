<Page
    x:Class="Rebound.ControlPanel.Views.SystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Rebound.ControlPanel.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Grid>
        <Grid
            Height="72"
            VerticalAlignment="Top"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Image
                Width="20"
                Margin="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Source="/Assets/Apps/SystemConfiguration.ico" />
            <TextBlock
                Margin="48,10"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                Text="System" />
            <TextBlock Margin="48,40,0,0" Text="System configuration, properties, environment variables." />
        </Grid>
        <ScrollViewer Margin="0,72,0,0" Padding="40,0,40,0">
            <StackPanel Spacing="8">
                <toolkit:SettingsCard
                    Margin="0,40,0,0"
                    Description="Manage the settings that don't appear here."
                    Header="Windows Settings"
                    IsClickEnabled="True">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE713;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <toolkit:SettingsCard.ActionIcon>
                        <FontIcon Glyph="&#xE8AD;" />
                    </toolkit:SettingsCard.ActionIcon>
                </toolkit:SettingsCard>
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="Computer information" />
                <toolkit:SettingsCard Description="The display name of your computer." Header="Computer name">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8AC;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <TextBox />
                </toolkit:SettingsCard>
                <toolkit:SettingsCard Description="The description of your computer." Header="Computer description">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE946;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <TextBox />
                </toolkit:SettingsCard>
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="Hardware" />
                <toolkit:SettingsCard
                    Description="Manage device drivers."
                    Header="Device Manager"
                    IsClickEnabled="True">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEB66;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <toolkit:SettingsCard.ActionIcon>
                        <FontIcon Glyph="&#xE8AD;" />
                    </toolkit:SettingsCard.ActionIcon>
                </toolkit:SettingsCard>
                <toolkit:SettingsCard Description="Automatically download device manufacturer apps." Header="OEM apps">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE74C;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <ToggleSwitch />
                </toolkit:SettingsCard>
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="Performance" />
                <toolkit:SettingsCard Description="Adjusts performance to favor the selected category. Hover over each option for more details." Header="Processor scheduling">
                    <ComboBox>
                        <ComboBoxItem Content="Apps and programs" ToolTipService.ToolTip="Best for home use." />
                        <ComboBoxItem Content="Background services" ToolTipService.ToolTip="Intended for servers and headless machines." />
                    </ComboBox>
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEC4A;" />
                    </toolkit:SettingsCard.HeaderIcon>
                </toolkit:SettingsCard>
                <muxc:InfoBar
                    Title="About pagefile"
                    IsClosable="False"
                    IsOpen="True"
                    Message="Windows pagefile is the equivalent of swap memory on UNIX systems, providing additional RAM by using the device's primary storage. Windows uses pagefile primarily for cache as disk read and write speeds tend to be slower compared to RAM." />
                <toolkit:SettingsCard Description="How Windows manages pagefile. Hover over each option for more details." Header="Pagefile management">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE83B;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <ComboBox>
                        <ComboBoxItem Content="Auto" ToolTipService.ToolTip="Windows will select the appropriate values for pagefile on your specific configuration." />
                        <ComboBoxItem Content="No pagefile (not recommended)" ToolTipService.ToolTip="No pagefile is provided. This option is not recommended as it can lead to issues with caching, latency, and crashes." />
                        <ComboBoxItem Content="Custom" ToolTipService.ToolTip="Configure pagefile to your desired size." />
                    </ComboBox>
                </toolkit:SettingsCard>
                <toolkit:SettingsCard Description="The size of your pagefile. Supports decimals and values in bytes, megabytes, gigabytes, etc." Header="Pagefile size">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEB05;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <TextBox Text="16 GB" />
                </toolkit:SettingsCard>
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="Bootloader" />
                <muxc:InfoBar
                    Title="About bootloader"
                    IsClosable="False"
                    IsOpen="True"
                    Message="The bootloader handles how the operating system starts. In case you're having trouble with drivers or you need to diagnose your system, modify these settings carefully." />
                <toolkit:SettingsCard Description="Select which operating system to load on the next boot." Header="Operating system">
                    <ComboBox>
                        <ComboBoxItem Content="Windows 11 (this)" />
                    </ComboBox>
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE770;" />
                    </toolkit:SettingsCard.HeaderIcon>
                </toolkit:SettingsCard>
                <Grid
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    ColumnSpacing="8"
                    CornerRadius="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontWeight="SemiBold"
                        Text="Bootloader parameters" />
                    <muxc:InfoBar
                        Title="The time to display each of these screens, in seconds. The value 0 makes them display forever until interacted with."
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="0,0,0,12"
                        IsClosable="False"
                        IsOpen="True" />
                    <muxc:NumberBox
                        Grid.Row="2"
                        Header="OS list"
                        SpinButtonPlacementMode="Compact"
                        Value="30" />
                    <muxc:NumberBox
                        Grid.Row="2"
                        Grid.Column="1"
                        Header="Recovery options"
                        SpinButtonPlacementMode="Compact"
                        Value="0" />
                </Grid>
                <toolkit:SettingsCard Description="Manages safe boot settings." Header="Safe boot">
                    <ComboBox>
                        <ComboBoxItem Content="Off" />
                        <ComboBoxItem Content="Minimal" />
                        <ComboBoxItem Content="Alternate shell" />
                        <ComboBoxItem Content="Active Directory repair" />
                        <ComboBoxItem Content="Network" />
                    </ComboBox>
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEC4A;" />
                    </toolkit:SettingsCard.HeaderIcon>
                </toolkit:SettingsCard>
                <Grid
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="0,0,0,8"
                        FontWeight="SemiBold"
                        Text="Boot parameters" />
                    <StackPanel Grid.Row="1">
                        <CheckBox Content="No GUI boot" />
                        <CheckBox Content="Boot log" />
                        <CheckBox Content="Base video (VGA mode)" />
                        <CheckBox Content="OS boot information" />
                    </StackPanel>
                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="2"
                        Spacing="8">
                        <muxc:NumberBox
                            Header="Number of processors (0 for default)"
                            SpinButtonPlacementMode="Compact"
                            Value="0" />
                        <TextBox Header="Maximum memory (0 for default)" Text="0 B" />
                    </StackPanel>
                </Grid>
                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button Content="Apply permanently" />
                    <Button Content="Reset to default" />
                    <Button Content="Apply for next boot" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="Blue Screen of Death (BSoD)" />
                <muxc:InfoBar
                    Title="About the BSoD"
                    IsClosable="False"
                    IsOpen="True"
                    Message="A BSoD typically shows up when your system encounters a critical error that it can not recover from. These can typically be caused by hardware failures, system corruption, power surges, etc." />
                <toolkit:SettingsCard Description="Restarts the system after writing dumps." Header="Automatically restart">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE777;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <ToggleSwitch />
                </toolkit:SettingsCard>
                <toolkit:SettingsCard Description="Logs the crash to the system logs to be viewed in Event Viewer." Header="Write an event to the system log">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xF000;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <ToggleSwitch />
                </toolkit:SettingsCard>
                <toolkit:SettingsCard Header="Write debugging information">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEBE8;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <ComboBox>
                        <ComboBoxItem Content="Small memory dump (256 KB)" />
                    </ComboBox>
                </toolkit:SettingsCard>
                <toolkit:SettingsCard Header="Small dump directory">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <TextBox Text="%SystemRoot%\Minidump" />
                </toolkit:SettingsCard>
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="Advanced" />
                <toolkit:SettingsCard
                    Description="Manage users on this machine."
                    Header="Users"
                    IsClickEnabled="True">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE716;" />
                    </toolkit:SettingsCard.HeaderIcon>
                </toolkit:SettingsCard>
                <toolkit:SettingsCard
                    Description="Windows startup, boot options, recovery."
                    Header="Boot and recovery"
                    IsClickEnabled="True">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEBC4;" />
                    </toolkit:SettingsCard.HeaderIcon>
                </toolkit:SettingsCard>
                <toolkit:SettingsCard
                    Description="Manage Windows system protection settings."
                    Header="System protection"
                    IsClickEnabled="True">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xF552;" />
                    </toolkit:SettingsCard.HeaderIcon>
                </toolkit:SettingsCard>
                <toolkit:SettingsCard
                    Description="View and manage Windows services."
                    Header="Services"
                    IsClickEnabled="True">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE9F5;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <toolkit:SettingsCard.ActionIcon>
                        <FontIcon Glyph="&#xE8AD;" />
                    </toolkit:SettingsCard.ActionIcon>
                </toolkit:SettingsCard>
                <toolkit:SettingsCard
                    Description="Manage startup apps in Task Manager."
                    Header="Startup apps"
                    IsClickEnabled="True">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xF120;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <toolkit:SettingsCard.ActionIcon>
                        <FontIcon Glyph="&#xE8AD;" />
                    </toolkit:SettingsCard.ActionIcon>
                </toolkit:SettingsCard>
                <toolkit:SettingsCard
                    Margin="0,40,0,40"
                    Description="Open the Windows Tools page to see all the available tools."
                    Header="View all Windows tools"
                    IsClickEnabled="True">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE90F;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <toolkit:SettingsCard.ActionIcon>
                        <FontIcon Glyph="&#xE8AD;" />
                    </toolkit:SettingsCard.ActionIcon>
                </toolkit:SettingsCard>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
