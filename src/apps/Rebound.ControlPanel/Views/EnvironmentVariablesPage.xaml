<Page
    x:Class="Rebound.ControlPanel.Views.EnvironmentVariablesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:Rebound.ControlPanel.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:viewModels="using:Rebound.ControlPanel.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolToVisibilityConverter
            x:Key="BoolToInverseVisibilityConverter"
            FalseValue="Visible"
            TrueValue="Collapsed" />
    </Page.Resources>
    <Grid>
        <Grid
            Height="72"
            VerticalAlignment="Top"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Image
                Width="20"
                Margin="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Source="/Assets/Apps/EnvironmentVariables.ico" />
            <TextBlock
                Margin="48,10"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                Text="Environment Variables" />
            <TextBlock Margin="48,40,0,0" Text="Change environment variables for the current user or all users." />
        </Grid>
        <ScrollViewer Margin="0,72,0,0" Padding="40,0,40,0">
            <StackPanel
                MaxWidth="1000"
                Margin="0,40"
                Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="User variables" />
                <Grid
                    Height="240"
                    Padding="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer>
                        <ListView ItemsSource="{x:Bind ViewModel.UserVariables}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:EnvironmentVariable">
                                    <Grid ToolTipService.ToolTip="{x:Bind Value, Mode=OneWay}">
                                        <StackPanel Margin="0,8">
                                            <TextBlock Text="{x:Bind Variable, Mode=OneWay}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind Value, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </Grid>
                <CommandBar DefaultLabelPosition="Right">
                    <AppBarButton Command="{x:Bind CreateUserEnvVarCommand}" Label="New">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE710;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="Edit">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE70F;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="Delete">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE74D;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="System variables" />
                <muxc:InfoBar
                    Title="These settings require administrator privileges to edit."
                    IsClosable="False"
                    IsOpen="True">
                    <muxc:InfoBar.ActionButton>
                        <Button Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xEA18;" />
                                <TextBlock Text="Relaunch as Administrator" />
                            </StackPanel>
                        </Button>
                    </muxc:InfoBar.ActionButton>
                </muxc:InfoBar>
                <Grid
                    Height="240"
                    Padding="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer>
                        <ListView ItemsSource="{x:Bind ViewModel.SystemVariables}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:EnvironmentVariable">
                                    <Grid ToolTipService.ToolTip="{x:Bind Value, Mode=OneWay}">
                                        <StackPanel Margin="0,8">
                                            <TextBlock Text="{x:Bind Variable, Mode=OneWay}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind Value, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </Grid>
                <CommandBar DefaultLabelPosition="Right">
                    <AppBarButton Label="New">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE710;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="Edit">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE70F;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="Delete">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE74D;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
