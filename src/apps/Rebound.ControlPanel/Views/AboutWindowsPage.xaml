<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Rebound.ControlPanel.Views.AboutWindowsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:Rebound.ControlPanel.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:CollectionVisibilityConverter x:Key="CollectionVisibilityConverter" />
        <converters:BoolToVisibilityConverter
            x:Key="BoolToInverseVisibilityConverter"
            FalseValue="Visible"
            TrueValue="Collapsed" />
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <converters:EmptyStringToObjectConverter
            x:Key="EmptyStringToObjectConverter"
            EmptyValue="False"
            NotEmptyValue="True" />
        <converters:FileSizeToFriendlyStringConverter x:Key="FileSizeToFriendlyStringConverter" />
        <converters:DoubleToObjectConverter
            x:Key="SelectedIndexToIsEnabledConverter"
            FalseValue="False"
            GreaterThan="-1"
            TrueValue="True" />
    </Page.Resources>
    <Grid>
        <Grid
            Height="72"
            VerticalAlignment="Top"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Image
                Width="20"
                Margin="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Source="/Assets/Glyphs/About.png" />
            <TextBlock
                Margin="48,10"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                Text="About Windows" />
            <TextBlock Margin="48,40,0,0" Text="View information about your PC." />
        </Grid>
        <ScrollView Margin="0,72,0,0" Padding="40,0,40,0">
            <StackPanel
                MaxWidth="1000"
                Margin="0,40"
                Spacing="8">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.OSName, Mode=OneWay}" />
                        <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.DetailedWindowsVersion, Mode=OneWay}" />
                    </StackPanel>

                    <!--  Logo  -->
                    <Viewbox
                        Grid.Column="1"
                        Height="80"
                        HorizontalAlignment="Right">
                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Orientation="Horizontal"
                            Spacing="24"
                            Visibility="{x:Bind ViewModel.ShowCustomBranding, Mode=OneWay, Converter={StaticResource BoolToInverseVisibilityConverter}}">
                            <Grid VerticalAlignment="Center">
                                <Path Data="M 0 4 C 0 2 2 0 4 0 L 33 0 L 33 33 L 0 33 M 35 0 L 64 0 C 66 0 68 2 68 4 L 68 33 L 35 33 M 33 35 L 0 35 L 0 64 C 0 66 2 68 4 68 L 33 68 M 35 35 L 68 35 L 68 64 C 68 66 66 68 64 68 L 35 68">
                                    <Path.Fill>
                                        <LinearGradientBrush StartPoint="0, 0" EndPoint="1, 1">
                                            <LinearGradientBrush.GradientStops>
                                                <GradientStop Color="{ThemeResource SystemAccentColorLight3}" />
                                                <GradientStop Offset="1" Color="{ThemeResource SystemAccentColor}" />
                                            </LinearGradientBrush.GradientStops>
                                        </LinearGradientBrush>
                                    </Path.Fill>
                                </Path>
                            </Grid>
                            <TextBlock
                                Margin="0,-8,0,0"
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI Variable"
                                FontSize="54"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.OSDisplayName, Mode=OneWay}">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0, 0" EndPoint="1, 1">
                                        <LinearGradientBrush.GradientStops>
                                            <GradientStop Offset="1" Color="{ThemeResource SystemAccentColorLight3}" />
                                            <GradientStop Color="{ThemeResource SystemAccentColorLight1}" />
                                        </LinearGradientBrush.GradientStops>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </Viewbox>

                    <!--  Custom logo  -->
                    <Grid
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Visibility="{x:Bind ViewModel.ShowCustomBranding, Mode=OneWay}">
                        <Image
                            Height="80"
                            Source="{x:Bind CustomLogoPath, Mode=OneWay}"
                            Stretch="Uniform" />
                    </Grid>
                </Grid>
                <TextBlock
                    Margin="0,8,0,0"
                    FontWeight="SemiBold"
                    Text="System information" />
                <toolkit:SettingsCard Description="The current computer's name" Header="Computer name">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE932;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.ComputerName, Mode=OneWay}" />
                </toolkit:SettingsCard>
                <InfoBar
                    Title="Windows Activation Status"
                    IsClosable="False"
                    IsOpen="True"
                    Message="{x:Bind ViewModel.WindowsActivationInfo, Mode=OneWay}"
                    Severity="{x:Bind WindowsActivationSeverity, Mode=OneWay}" />
                <TextBlock
                    Margin="0,32,0,0"
                    FontWeight="SemiBold"
                    Text="Hardware information" />
                <toolkit:SettingsCard Description="The processor's name and architecture" Header="CPU">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEEA1;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <StackPanel>
                        <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.CpuName, Mode=OneWay}" />
                        <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.CpuArchitecture, Mode=OneWay}" />
                    </StackPanel>
                </toolkit:SettingsCard>
                <toolkit:SettingsCard Description="The graphics card's name" Header="GPU">
                    <toolkit:SettingsCard.HeaderIcon>
                        <PathIcon Data="F1 M 0 5 C 0 4 1 3 2 3 L 14 3 C 15 3 16 4 16 5 L 16 9 C 16 10 15 11 14 11 L 2 11 C 1 11 0 10 0 9 M 1 5 L 1 9 C 1 9.5 1.5 10 2 10 L 14 10 C 14.5 10 15 9.5 15 9 L 15 5 C 15 4.5 14.5 4 14 4 L 2 4 C 1.5 4 1 4.5 1 5 M 14 11 L 14 13 L 6 13 L 6 11 M 7 11 L 7 12 L 13 12 L 13 11 M 4 5 A 1 1 0 0 0 4 9 A 1 1 0 0 0 4 5 M 4 6 A 1 1 0 0 1 4 8 A 1 1 0 0 1 4 6 M 12 5 A 1 1 0 0 0 12 9 A 1 1 0 0 0 12 5 M 12 6 A 1 1 0 0 1 12 8 A 1 1 0 0 1 12 6 M 8 6 A 1 1 0 0 1 8 8 A 1 1 0 0 1 8 6 M 8 5 A 1 1 0 0 0 8 9 A 1 1 0 0 0 8 5" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.GpuName, Mode=OneWay}" />
                </toolkit:SettingsCard>
                <toolkit:SettingsExpander
                    Description="RAM and pagefile memory"
                    Header="Memory"
                    IsExpanded="True">
                    <toolkit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xEEA0;" />
                    </toolkit:SettingsExpander.HeaderIcon>
                    <toolkit:SettingsExpander.Items>
                        <toolkit:SettingsCard Header="Installed RAM">
                            <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.InstalledRam, Mode=OneWay, Converter={StaticResource FileSizeToFriendlyStringConverter}}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Header="Usable RAM">
                            <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.UsableRam, Mode=OneWay, Converter={StaticResource FileSizeToFriendlyStringConverter}}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Header="Pagefile size">
                            <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.PagefileSize, Mode=OneWay, Converter={StaticResource FileSizeToFriendlyStringConverter}}" />
                        </toolkit:SettingsCard>
                    </toolkit:SettingsExpander.Items>
                </toolkit:SettingsExpander>
                <toolkit:SettingsCard Description="Windows partition and total storage capacity" Header="Storage">
                    <toolkit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEDA2;" />
                    </toolkit:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <StackPanel Spacing="8">
                            <Grid>
                                <ProgressRing
                                    Width="40"
                                    Height="40"
                                    Background="{ThemeResource SystemControlBackgroundAltMediumLowBrush}"
                                    IsIndeterminate="False"
                                    Value="{x:Bind ViewModel.WindowsOccupiedSpace, Mode=OneWay}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}">
                                    <Run Text="{x:Bind ViewModel.WindowsOccupiedSpaceString, Mode=OneWay}" /><Run Text="%" /></TextBlock>
                            </Grid>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Windows" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <Grid>
                                <ProgressRing
                                    Width="40"
                                    Height="40"
                                    Background="{ThemeResource SystemControlBackgroundAltMediumLowBrush}"
                                    IsIndeterminate="False"
                                    Value="{x:Bind ViewModel.TotalOccupiedSpace, Mode=OneWay}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}">
                                    <Run Text="{x:Bind ViewModel.TotalOccupiedSpaceString, Mode=OneWay}" /><Run Text="%" /></TextBlock>
                            </Grid>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Total" />
                        </StackPanel>
                    </StackPanel>
                </toolkit:SettingsCard>
                <toolkit:SettingsExpander Description="Device and motherboard details" Header="Device information">
                    <toolkit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE7F8;" />
                    </toolkit:SettingsExpander.HeaderIcon>
                    <toolkit:SettingsExpander.Items>
                        <toolkit:SettingsCard Header="Device manufacturer">
                            <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.DeviceManufacturer, Mode=OneWay}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Header="Device model">
                            <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.DeviceModel, Mode=OneWay}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Header="Motherboard model">
                            <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.MotherboardModel, Mode=OneWay}" />
                        </toolkit:SettingsCard>
                    </toolkit:SettingsExpander.Items>
                </toolkit:SettingsExpander>
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>